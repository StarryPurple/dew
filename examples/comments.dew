// Comments demo: Dew supports three comment styles
/// Doc comment — triple slash
//  C++ style — double slash
#   Shell style — hash

/// Compute n factorial
def fact = fix f: Int -> Int {
    fn (n: Int) {
        if (n < 2) { 1 }
        else { n * f(n - 1) } // recursive case
    }
};

// Entry point
def main = fn () {
    fact(5)  # returns 120
}
