// expect: 5050
// Tier: Medium
// Large: borrow + recursion + struct + if/else (§5.5 Rules 1, 2, 5).
// Compute triangular number T(n) = n*(n+1)/2 using borrow-incremented accumulator.
struct Acc { value: Int }
def rec loop = fn(n: Int, &acc: Acc) -> Acc {
  if n == 0 { acc }
  else {
    &acc { value = acc.value + n };
    loop(n - 1, &acc)
  }
};
def main = fn {
  def acc = Acc { value: 0 };
  def result = loop(100, &acc);
  result.value -> stdout;
};
