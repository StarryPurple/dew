// expect: 6
// Tier: Medium
// Recursive enum: binary tree with integers at leaves.
enum Tree { Leaf(Int), Node(Tree, Tree) }
def sum_tree = fn(t: Tree) -> Int {
  match t {
    Leaf(n) => n,
    Node(left, right) => sum_tree(left) + sum_tree(right),
  }
};
def main = fn { sum_tree(Node(Leaf(1), Leaf(5))) -> stdout; };
