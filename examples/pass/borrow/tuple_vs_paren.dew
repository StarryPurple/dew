// expect: 42
// Tier: Medium
// Feature: single-element tuple (x,) vs parenthesized expression (x)
// if-borrow returns tuple, destructure extracts single element
// (x,) is a single-element tuple with trailing comma
def main = fn {
  def x = 0;
  if (&x; true) { &x = 42 };
  def y = (42,);
  def first = y.0;
  first -> stdout
}
