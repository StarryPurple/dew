// stdlib/list/reverse.dew — reverse a list
// reverse(xs): returns reversed copy
// Uses accumulator-passing style, O(n)

def reverse = fix rev: List(Int) -> (List(Int) -> List(Int)) {
    fn (xs: List(Int)) { fn (acc: List(Int)) {
        if isnil(xs) { acc } else { rev(tail(xs))(cons(head(xs), acc)) }
    }}
};

def main = fn () {
    reverse([1, 2, 3])(nil) |> head
}
