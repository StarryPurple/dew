// stdlib/list/set/member.dew — set membership test
// member(x, xs): is x in the set xs?
// Assumes xs has no duplicates (set property)

def member = fix mem: List(Int) -> (Int -> Bool) {
    fn (xs: List(Int)) { fn (x: Int) {
        if isnil(xs) { false } else {
            if head(xs) == x { true } else { mem(tail(xs))(x) }
        }
    }}
};

def main = fn () {
    def s = [2, 3, 5, 7, 11];
    if member(s)(7) { 100 } else { 0 }
}
