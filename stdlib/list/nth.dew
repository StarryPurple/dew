// stdlib/list/nth.dew — indexed access
// nth(n, xs): get element at index n (0-based)
// O(n) time, works with lazy lists

def nth = fix nth: Int -> (List(Int) -> Int) {
    fn (n: Int) { fn (xs: List(Int)) {
        if (n == 0) { head(xs) } else { nth(n - 1)(tail(xs)) }
    }}
};

// Entry point for testing
def main = fn () {
    nth(2)([10, 20, 30, 40])
}
