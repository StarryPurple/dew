{
  "scopeName": "source.dewir",
  "patterns": [{ "include": "#comments" }, { "include": "#keywords" }],
  "repository": {
    "comments": { "patterns": [{ "match": ";.*", "name": "comment.line" }] },
    "keywords": {
      "patterns": [
        { "match": "\\b(thunk|fn|ret|br|jmp|phi|lit|add|sub|mul|div|rem|lt|gt|le|ge|eq|ne|and|or|not|call|force|lambda|entry|merge|struct_cons|struct_update|enum_cons|enum_disc|enum_proj|array_lit|array_fill|array_access|array_update|tuple_lit|tuple_update|Move)\\b", "name": "keyword.control" },
        { "match": "\\b[0-9]+\\b", "name": "constant.numeric" },
        { "match": "@[a-zA-Z_][a-zA-Z0-9_]*|%[a-zA-Z_][a-zA-Z0-9_]*", "name": "variable.other" }
      ]
    }
  }
}
