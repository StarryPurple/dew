{
  "name": "dew",
  "displayName": "Dew Language Support",
  "description": "Dew language support with syntax highlighting, diagnostics, hover, and go-to-definition",
  "version": "0.1.0",
  "publisher": "dew-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:dew"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dew",
        "extensions": [
          ".dew"
        ],
        "aliases": [
          "Dew"
        ]
      }
    ],
    "grammars": [
      {
        "language": "dew",
        "scopeName": "source.dew",
        "path": "./syntaxes/dew.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[dew]": {
        "editor.tabSize": 2
      }
    },
    "configuration": {
      "title": "Dew",
      "language": "dew",
      "path": "./language-configuration.json",
      "properties": {
        "dew.serverPath": {
          "type": "string",
          "default": "dew",
          "description": "Path to the dew binary"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
