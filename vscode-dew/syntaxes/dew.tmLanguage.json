{
    "name": "Dew",
    "scopeName": "source.dew",
    "fileTypes": ["dew"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#functions" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                { "name": "comment.line.double-slash.dew", "match": "//.*$" },
                { "name": "comment.line.hash.dew", "match": "#.*$" },
                { "name": "comment.block.dew", "begin": "/\\*", "end": "\\*/" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.dew", "match": "\\b(if|else|match|def|fix|dup|include)\\b" },
                { "name": "keyword.operator.dew", "match": "\\b(fn|type)\\b" },
                { "name": "keyword.other.dew", "match": "\\b(nil|cons|head|tail|isnil|box|unbox|vector|vget)\\b" },
                { "name": "storage.type.dew", "match": "\\b(Int|Bool|Unit|Box|List)\\b" },
                { "name": "constant.language.dew", "match": "\\b(true|false)\\b" }
            ]
        },
        "types": {
            "patterns": [
                { "name": "entity.name.type.dew", "match": "\\b[A-Z][a-zA-Z0-9_]*\\b" }
            ]
        },
        "constants": {
            "patterns": [
                { "name": "constant.numeric.dew", "match": "\\b[0-9]+\\b" }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.arrow.dew", "match": "->|\\|>" },
                { "name": "keyword.operator.comparison.dew", "match": "==|!=|<|>|<=|>=" },
                { "name": "keyword.operator.arithmetic.dew", "match": "[+\\-*/%]" },
                { "name": "keyword.operator.assignment.dew", "match": "=" },
                { "name": "keyword.operator.pipe.dew", "match": "\\|>" },
                { "name": "keyword.operator.bang.dew", "match": "!" }
            ]
        },
        "strings": {
            "patterns": [
                { "name": "string.quoted.double.dew", "begin": "\"", "end": "\"" }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.integer.dew", "match": "\\b[0-9]+\\b" }
            ]
        },
        "functions": {
            "patterns": [
                { "name": "entity.name.function.dew", "match": "\\b[a-z_][a-zA-Z0-9_]*\\s*(?=\\()" }
            ]
        }
    }
}
